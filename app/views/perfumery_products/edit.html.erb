<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card">
        <div class="card-header">
          <h2><i class="bi bi-droplet-half"></i> Editar Produto de Perfumaria</h2>
        </div>
        <div class="card-body">
          <%= form_with model: @perfumery_product, local: true, class: 'needs-validation', novalidate: true do |form| %>
            <% if @perfumery_product.errors.any? %>
              <div class="alert alert-danger">
                <h4>Erros encontrados:</h4>
                <ul>
                  <% @perfumery_product.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row">
              <div class="col-md-8 mb-3">
                <%= form.label :name, 'Nome do Produto *', class: 'form-label' %>
                <%= form.text_field :name, class: 'form-control', required: true %>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :category, 'Categoria *', class: 'form-label' %>
                <%= form.select :category, PerfumeryProduct::CATEGORIES.map { |c| [c, c] }, { prompt: 'Selecione a categoria' }, class: 'form-select', required: true %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-4 mb-3">
                <%= form.label :brand, 'Marca *', class: 'form-label' %>
                <%= form.text_field :brand, class: 'form-control', required: true %>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :volume_ml, 'Volume (ml)', class: 'form-label' %>
                <%= form.number_field :volume_ml, class: 'form-control', min: 1 %>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :fragrance_type, 'Tipo de fragrância', class: 'form-label' %>
                <%= form.select :fragrance_type, PerfumeryProduct::FRAGRANCE_TYPES.map { |f| [f, f] }, { prompt: 'Selecione (opcional)', include_blank: true }, class: 'form-select' %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-3 mb-3">
                <%= form.label :price, 'Preço (R$) *', class: 'form-label' %>
                <%= form.number_field :price, class: 'form-control', required: true, min: 0, step: 0.01 %>
              </div>

              <div class="col-md-3 mb-3">
                <%= form.label :discount_percentage, 'Desconto (%)', class: 'form-label' %>
                <%= form.number_field :discount_percentage, class: 'form-control', min: 0, max: 100, step: 0.5, value: @perfumery_product.discount_percentage || 0 %>
                <div class="form-text">Opcional. 0 a 100.</div>
              </div>

              <div class="col-md-3 mb-3">
                <%= form.label :stock_quantity, 'Quantidade em estoque', class: 'form-label' %>
                <%= form.number_field :stock_quantity, class: 'form-control', min: 0 %>
              </div>

              <div class="col-md-3 mb-3">
                <%= form.label :minimum_stock, 'Estoque mínimo', class: 'form-label' %>
                <%= form.number_field :minimum_stock, class: 'form-control', min: 0 %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :manufacturer, 'Fabricante', class: 'form-label' %>
                <%= form.text_field :manufacturer, class: 'form-control' %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :barcode, 'Código de barras', class: 'form-label' %>
                <%= form.text_field :barcode, class: 'form-control' %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :description, 'Descrição', class: 'form-label' %>
              <%= form.text_area :description, class: 'form-control', rows: 3 %>
            </div>

            <div class="mb-3">
              <div class="form-check">
                <%= form.check_box :is_active, class: 'form-check-input' %>
                <%= form.label :is_active, 'Produto ativo', class: 'form-check-label' %>
              </div>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to 'Voltar', perfumery_product_path(@perfumery_product), class: 'btn btn-secondary' %>
              <%= form.submit 'Atualizar Produto', class: 'btn btn-primary' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
