<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <h2 class="text-center mb-0">Pedido de Medicamento - Programa de Apoio</h2>
        </div>
        <div class="card-body">
          <%= form_with(model: @medication_request, local: true, class: "needs-validation", novalidate: true) do |form| %>
            <div class="mb-3">
              <%= form.label :name, "Nome Completo", class: "form-label" %>
              <%= form.text_field :name, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :cpf, "CPF", class: "form-label" %>
              <%= form.text_field :cpf, class: "form-control", required: true, data: { mask: "000.000.000-00" } %>
            </div>

            <div class="mb-3">
              <%= form.label :address, "Endereço Completo", class: "form-label" %>
              <%= form.text_area :address, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :phone, "Telefone", class: "form-label" %>
              <%= form.telephone_field :phone, class: "form-control", required: true, data: { mask: "(00) 00000-0000" } %>
            </div>

            <div class="mb-3">
              <%= form.label :email, "E-mail", class: "form-label" %>
              <%= form.email_field :email, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :monthly_income, "Renda Mensal (R$)", class: "form-label" %>
              <%= form.number_field :monthly_income, class: "form-control", required: true, step: "0.01" %>
            </div>

            <div class="mb-3">
              <%= form.label :medication_name, "Nome do Medicamento", class: "form-label" %>
              <%= form.text_field :medication_name, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :prescription_photo, "Foto da Receita Médica", class: "form-label" %>
              <%= form.file_field :prescription_photo, class: "form-control", required: true, accept: "image/*" %>
            </div>

            <div class="mb-3">
              <%= form.label :additional_info, "Informações Adicionais", class: "form-label" %>
              <%= form.text_area :additional_info, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :doctor_crm, "CRM do Médico", class: "form-label" %>
              <%= form.text_field :doctor_crm, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :venous_application_notes, "Observações da Aplicação Venosa", class: "form-label" %>
              <%= form.text_area :venous_application_notes, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :medication_quantity, "Quantidade de Medicação", class: "form-label" %>
              <%= form.number_field :medication_quantity, class: "form-control", required: true, step: "0.01" %>
            </div>

            <div class="text-center">
              <%= form.submit "Enviar Pedido", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }
  
  .form-control:focus {
    border-color: #80bdff;
    box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
  }
  
  .btn-primary {
    padding: 10px 30px;
  }
</style> 