<div class="container mt-4">
  <div class="row">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <div class="d-flex justify-content-between align-items-center">
            <h2><%= @promotion.name %></h2>
            <div>
              <%= link_to 'Editar', edit_promotion_path(@promotion), class: 'btn btn-warning' %>
              <%= link_to 'Voltar', promotions_path, class: 'btn btn-secondary' %>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <h5>Informações da Promoção</h5>
              <table class="table table-borderless">
                <tr>
                  <td><strong>Status:</strong></td>
                  <td>
                    <span class="badge <%= @promotion.status_badge_class %> fs-6">
                      <%= @promotion.status_label %>
                    </span>
                  </td>
                </tr>
                <tr>
                  <td><strong>Suplemento:</strong></td>
                  <td>
                    <%= link_to @promotion.supplement.name, supplement_path(@promotion.supplement), class: 'text-decoration-none' %>
                  </td>
                </tr>
                <tr>
                  <td><strong>Tipo de Desconto:</strong></td>
                  <td>
                    <span class="badge bg-secondary">
                      <%= @promotion.discount_type == 'percentage' ? 'Percentual' : 'Valor Fixo' %>
                    </span>
                  </td>
                </tr>
                <tr>
                  <td><strong>Valor do Desconto:</strong></td>
                  <td>
                    <% if @promotion.discount_type == 'percentage' %>
                      <span class="h5 text-danger"><%= number_with_precision(@promotion.discount_value, precision: 1) %>%</span>
                    <% else %>
                      <span class="h5 text-danger">R$ <%= number_with_precision(@promotion.discount_value, precision: 2) %></span>
                    <% end %>
                  </td>
                </tr>
                <tr>
                  <td><strong>Data de Início:</strong></td>
                  <td><%= @promotion.start_date.strftime('%d/%m/%Y') %></td>
                </tr>
                <tr>
                  <td><strong>Data de Término:</strong></td>
                  <td><%= @promotion.end_date.strftime('%d/%m/%Y') %></td>
                </tr>
              </table>
            </div>
            <div class="col-md-6">
              <h5>Informações de Preço</h5>
              <table class="table table-borderless">
                <tr>
                  <td><strong>Preço Original:</strong></td>
                  <td>
                    <span class="h5 text-muted">
                      R$ <%= number_with_precision(@promotion.supplement.price, precision: 2) %>
                    </span>
                  </td>
                </tr>
                <tr>
                  <td><strong>Desconto:</strong></td>
                  <td>
                    <span class="h5 text-danger">
                      - R$ <%= number_with_precision(@promotion.discount_amount(@promotion.supplement.price), precision: 2) %>
                    </span>
                  </td>
                </tr>
                <tr>
                  <td><strong>Preço Promocional:</strong></td>
                  <td>
                    <span class="h3 text-success">
                      R$ <%= number_with_precision(@promotion.calculate_discounted_price(@promotion.supplement.price), precision: 2) %>
                    </span>
                  </td>
                </tr>
                <tr>
                  <td><strong>Economia:</strong></td>
                  <td>
                    <span class="h5 text-success">
                      R$ <%= number_with_precision(@promotion.discount_amount(@promotion.supplement.price), precision: 2) %>
                    </span>
                  </td>
                </tr>
              </table>
            </div>
          </div>

          <% if @promotion.description.present? %>
            <div class="mt-4">
              <h5>Descrição</h5>
              <p class="text-muted"><%= @promotion.description %></p>
            </div>
          <% end %>

          <div class="mt-4">
            <h5>Informações do Suplemento</h5>
            <div class="card bg-light">
              <div class="card-body">
                <div class="row">
                  <div class="col-md-6">
                    <p><strong>Tipo:</strong> <%= @promotion.supplement.supplement_type %></p>
                    <p><strong>Peso:</strong> <%= @promotion.supplement.weight %></p>
                    <% if @promotion.supplement.flavor.present? %>
                      <p><strong>Sabor:</strong> <%= @promotion.supplement.flavor %></p>
                    <% end %>
                  </div>
                  <div class="col-md-6">
                    <p><strong>Fabricante:</strong> <%= @promotion.supplement.manufacturer %></p>
                    <p><strong>Estoque:</strong> <%= @promotion.supplement.stock_quantity %> unidades</p>
                    <p>
                      <strong>Disponível:</strong>
                      <span class="badge <%= @promotion.supplement.available_for_sale? ? 'bg-success' : 'bg-danger' %>">
                        <%= @promotion.supplement.available_for_sale? ? 'Sim' : 'Não' %>
                      </span>
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <div class="card-header">
          <h5>Ações Rápidas</h5>
        </div>
        <div class="card-body">
          <%= link_to 'Ver Suplemento', supplement_path(@promotion.supplement), 
              class: 'btn btn-primary btn-lg w-100 mb-2' %>
          <%= link_to 'Todas as Promoções', promotions_path, 
              class: 'btn btn-outline-info w-100 mb-2' %>
        </div>
      </div>

      <div class="card mt-3">
        <div class="card-header">
          <h5>Status da Promoção</h5>
        </div>
        <div class="card-body">
          <div class="text-center">
            <span class="badge <%= @promotion.status_badge_class %> fs-5 p-3">
              <%= @promotion.status_label %>
            </span>
          </div>
          <% if @promotion.current? %>
            <div class="alert alert-success mt-3 mb-0">
              <i class="bi bi-check-circle"></i>
              Esta promoção está ativa e pode ser aplicada nas vendas.
            </div>
          <% elsif @promotion.expired? %>
            <div class="alert alert-danger mt-3 mb-0">
              <i class="bi bi-x-circle"></i>
              Esta promoção expirou em <%= @promotion.end_date.strftime('%d/%m/%Y') %>.
            </div>
          <% elsif @promotion.not_started? %>
            <div class="alert alert-warning mt-3 mb-0">
              <i class="bi bi-clock"></i>
              Esta promoção começará em <%= @promotion.start_date.strftime('%d/%m/%Y') %>.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
