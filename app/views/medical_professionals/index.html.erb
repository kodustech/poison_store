<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Profissionais Médicos</h1>
        <%= link_to 'Novo Profissional', new_medical_professional_path, class: 'btn btn-primary' %>
      </div>

      <!-- Filtros e Busca -->
      <div class="card mb-4">
        <div class="card-body">
          <%= form_with url: medical_professionals_path, method: :get, local: true, class: 'row g-3' do |form| %>
            <div class="col-md-4">
              <%= form.label :search, 'Buscar por nome, CRM ou especialidade', class: 'form-label' %>
              <%= form.text_field :search, value: params[:search], class: 'form-control', placeholder: 'Digite para buscar...' %>
            </div>
            
            <div class="col-md-3">
              <%= form.label :specialty, 'Especialidade', class: 'form-label' %>
              <%= form.select :specialty, options_for_select([['Todas', '']] + @specialties.map { |s| [s, s] }, params[:specialty]), {}, class: 'form-select' %>
            </div>
            
            <div class="col-md-3">
              <%= form.label :city, 'Cidade', class: 'form-label' %>
              <%= form.select :city, options_for_select([['Todas', '']] + @cities.map { |c| [c, c] }, params[:city]), {}, class: 'form-select' %>
            </div>
            
            <div class="col-md-2 d-flex align-items-end">
              <%= form.submit 'Filtrar', class: 'btn btn-outline-primary me-2' %>
              <%= link_to 'Limpar', medical_professionals_path, class: 'btn btn-outline-secondary' %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Lista de Profissionais -->
      <div class="card">
        <div class="card-body">
          <% if @medical_professionals.any? %>
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>CRM</th>
                    <th>Especialidade</th>
                    <th>Telefone</th>
                    <th>Cidade</th>
                    <th>Desconto</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% @medical_professionals.each do |professional| %>
                    <tr>
                      <td><strong><%= professional.name %></strong></td>
                      <td><span class="badge bg-info"><%= professional.crm %></span></td>
                      <td><%= professional.specialty %></td>
                      <td><%= professional.phone %></td>
                      <td><%= professional.city %></td>
                      <td>
                        <span class="badge bg-success">
                          <%= number_to_percentage(professional.discount_percentage, precision: 0) %>
                        </span>
                      </td>
                      <td>
                        <% if professional.active? %>
                          <span class="badge bg-success">Ativo</span>
                        <% else %>
                          <span class="badge bg-danger">Inativo</span>
                        <% end %>
                      </td>
                      <td>
                        <div class="btn-group" role="group">
                          <%= link_to 'Ver', medical_professional_path(professional), class: 'btn btn-sm btn-outline-primary' %>
                          <%= link_to 'Editar', edit_medical_professional_path(professional), class: 'btn btn-sm btn-outline-warning' %>
                          <%= link_to 'Remover', medical_professional_path(professional), 
                              method: :delete, 
                              data: { confirm: 'Tem certeza que deseja remover este profissional?' },
                              class: 'btn btn-sm btn-outline-danger' %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            
            <div class="mt-3">
              <small class="text-muted">
                Total de profissionais: <strong><%= @medical_professionals.count %></strong>
              </small>
            </div>
          <% else %>
            <div class="text-center py-4">
              <p class="text-muted">Nenhum profissional médico encontrado.</p>
              <%= link_to 'Cadastrar primeiro profissional', new_medical_professional_path, class: 'btn btn-primary' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
