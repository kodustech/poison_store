<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Relatório - Medicamentos Mais Vendidos no Mês</h2>
    <div>
      <%= link_to "Voltar aos Relatórios", reports_path, class: "btn btn-secondary" %>
      <%= link_to "Relatório Mensal Completo", monthly_sales_report_path, class: "btn btn-outline-primary" %>
    </div>
  </div>

  <!-- Filtros -->
  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Filtros de Período</h5>
      <%= form_tag top_medications_reports_path, method: :get, class: "mb-0" do %>
        <div class="row">
          <div class="col-md-3">
            <div class="form-group mb-3">
              <%= label_tag :start_date, "Data Inicial", class: "form-label" %>
              <%= date_field_tag :start_date, @start_date, class: "form-control" %>
            </div>
          </div>
          <div class="col-md-3">
            <div class="form-group mb-3">
              <%= label_tag :end_date, "Data Final", class: "form-label" %>
              <%= date_field_tag :end_date, @end_date, class: "form-control" %>
            </div>
          </div>
          <div class="col-md-3">
            <div class="form-group mb-3">
              <%= label_tag :limit, "Quantidade de Resultados", class: "form-label" %>
              <%= select_tag :limit, 
                  options_for_select([
                    ['Top 10', 10],
                    ['Top 25', 25], 
                    ['Top 50', 50],
                    ['Todos', 0]
                  ], @limit), 
                  class: "form-select" %>
            </div>
          </div>
          <div class="col-md-3 d-flex align-items-end">
            <div class="form-group mb-3 w-100">
              <%= submit_tag "Filtrar", class: "btn btn-primary w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Resumo do Período -->
  <div class="alert alert-info mb-4">
    <i class="fas fa-info-circle"></i>
    Exibindo 
    <% if @limit > 0 %>
      <strong>top <%= @limit %></strong> medicamentos
    <% else %>
      <strong>todos</strong> os medicamentos
    <% end %>
    do período de <strong><%= @start_date.strftime("%d/%m/%Y") %></strong> a <strong><%= @end_date.strftime("%d/%m/%Y") %></strong>
    <% if @top_medications.any? %>
      - Total de <strong><%= @top_medications.count %></strong> medicamentos encontrados
    <% end %>
  </div>

  <!-- Tabela de Medicamentos -->
  <% if @top_medications.any? %>
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Ranking de Medicamentos Mais Vendidos</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th style="width: 60px;">#</th>
                <th>Medicamento</th>
                <th class="text-center">Quantidade Vendida</th>
                <th class="text-center">Nº de Transações</th>
                <th class="text-end">Receita Total</th>
                <th class="text-end">Preço Médio</th>
                <th class="text-center">Com Receita</th>
                <th class="text-center">Sem Receita</th>
              </tr>
            </thead>
            <tbody>
              <% @top_medications.each_with_index do |medication, index| %>
                <tr>
                  <td>
                    <span class="badge bg-primary fs-6"><%= index + 1 %></span>
                  </td>
                  <td>
                    <strong><%= medication[:medication_name] %></strong>
                  </td>
                  <td class="text-center">
                    <span class="badge bg-success fs-6"><%= medication[:total_quantity] %> un</span>
                  </td>
                  <td class="text-center">
                    <span class="badge bg-secondary"><%= medication[:number_of_sales] %></span>
                  </td>
                  <td class="text-end">
                    <strong class="text-success">R$ <%= number_with_precision(medication[:total_revenue], precision: 2) %></strong>
                  </td>
                  <td class="text-end">
                    <small class="text-muted">R$ <%= number_with_precision(medication[:average_price], precision: 2) %></small>
                  </td>
                  <td class="text-center">
                    <% if medication[:with_prescription] > 0 %>
                      <span class="badge bg-warning"><%= medication[:with_prescription] %></span>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>
                  <td class="text-center">
                    <% if medication[:without_prescription] > 0 %>
                      <span class="badge bg-info"><%= medication[:without_prescription] %></span>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer bg-light">
        <div class="row text-center">
          <div class="col-md-4">
            <strong>Total de Unidades:</strong>
            <span class="text-success"><%= @top_medications.sum { |m| m[:total_quantity] } %></span>
          </div>
          <div class="col-md-4">
            <strong>Receita Total:</strong>
            <span class="text-success">R$ <%= number_with_precision(@top_medications.sum { |m| m[:total_revenue] }, precision: 2) %></span>
          </div>
          <div class="col-md-4">
            <strong>Total de Transações:</strong>
            <span><%= @top_medications.sum { |m| m[:number_of_sales] } %></span>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="alert alert-warning text-center">
      <i class="fas fa-exclamation-triangle"></i>
      Nenhum medicamento vendido encontrado para o período selecionado.
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to "Buscar Médicos", search_doctors_reports_path, class: "btn btn-outline-secondary" %>
  </div>
</div> 