<div class="container mt-4">
  <h1>Relatório de Atividades</h1>
  <p class="text-muted">Período: <%= display_period_start %> a <%= format_date(@period_end) %></p>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Cliente</th>
        <th>Data da venda</th>
        <th>Valor</th>
      </tr>
    </thead>
    <tbody>
      <% @activities.each do |activity| %>
        <tr>
          <td><%= activity.customer_name %></td>
          <td><%= format_activity_sale_date(activity) %></td>
          <td><%= number_to_currency(activity.total_price, unit: 'R$ ') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <footer class="mt-4 text-muted small">
    Relatório gerado em: <%= report_generated_at %>
  </footer>
</div>
