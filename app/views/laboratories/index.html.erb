<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Laboratórios</h1>
        <%= link_to 'Novo Laboratório', new_laboratory_path, class: 'btn btn-primary' %>
      </div>

      <!-- Filtros e Busca -->
      <div class="card mb-4">
        <div class="card-body">
          <%= form_with url: laboratories_path, method: :get, local: true, class: 'row g-3' do |form| %>
            <div class="col-md-4">
              <%= form.label :search, 'Buscar por nome, CNPJ ou cidade', class: 'form-label' %>
              <%= form.text_field :search, value: params[:search], class: 'form-control', placeholder: 'Digite para buscar...' %>
            </div>
            
            <div class="col-md-3">
              <%= form.label :state, 'Estado', class: 'form-label' %>
              <%= form.select :state, options_for_select([['Todos', '']] + @states.map { |s| [s, s] }, params[:state]), {}, class: 'form-select' %>
            </div>

            <div class="col-md-3">
              <%= form.label :active, 'Status', class: 'form-label' %>
              <%= form.select :active, options_for_select([['Todos', ''], ['Ativos', 'true'], ['Inativos', 'false']], params[:active]), {}, class: 'form-select' %>
            </div>
            
            <div class="col-md-2 d-flex align-items-end">
              <%= form.submit 'Filtrar', class: 'btn btn-outline-primary me-2' %>
              <%= link_to 'Limpar', laboratories_path, class: 'btn btn-outline-secondary' %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Lista de Laboratórios -->
      <div class="card">
        <div class="card-body">
          <% if @laboratories.any? %>
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>CNPJ</th>
                    <th>Contato</th>
                    <th>Cidade/Estado</th>
                    <th>Medicamentos</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% @laboratories.each do |laboratory| %>
                    <tr>
                      <td><strong><%= laboratory.name %></strong></td>
                      <td><%= laboratory.cnpj %></td>
                      <td>
                        <% if laboratory.contact_person.present? %>
                          <%= laboratory.contact_person %><br>
                        <% end %>
                        <% if laboratory.phone.present? %>
                          <small class="text-muted"><%= laboratory.phone %></small>
                        <% end %>
                      </td>
                      <td>
                        <%= laboratory.city %><br>
                        <small class="text-muted"><%= laboratory.state %></small>
                      </td>
                      <td>
                        <span class="badge bg-info">
                          <%= laboratory.potions.count %> medicamento(s)
                        </span>
                      </td>
                      <td>
                        <% if laboratory.active? %>
                          <span class="badge bg-success">Ativo</span>
                        <% else %>
                          <span class="badge bg-danger">Inativo</span>
                        <% end %>
                      </td>
                      <td>
                        <div class="btn-group" role="group">
                          <%= link_to 'Ver', laboratory_path(laboratory), class: 'btn btn-sm btn-outline-primary' %>
                          <%= link_to 'Editar', edit_laboratory_path(laboratory), class: 'btn btn-sm btn-outline-warning' %>
                          <%= link_to 'Remover', laboratory_path(laboratory), 
                              method: :delete, 
                              data: { confirm: 'Tem certeza que deseja remover este laboratório?' },
                              class: 'btn btn-sm btn-outline-danger' %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            
            <div class="mt-3">
              <small class="text-muted">
                Total de laboratórios: <strong><%= @laboratories.count %></strong>
              </small>
            </div>
          <% else %>
            <div class="text-center py-4">
              <p class="text-muted">Nenhum laboratório encontrado.</p>
              <%= link_to 'Cadastrar primeiro laboratório', new_laboratory_path, class: 'btn btn-primary' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

