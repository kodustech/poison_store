<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card">
        <div class="card-header">
          <h2>Novo Suplemento</h2>
        </div>
        <div class="card-body">
          <%= form_with model: @supplement, local: true, class: 'needs-validation', novalidate: true do |form| %>
            <% if @supplement.errors.any? %>
              <div class="alert alert-danger">
                <h4>Erros encontrados:</h4>
                <ul>
                  <% @supplement.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row">
              <div class="col-md-8 mb-3">
                <%= form.label :name, 'Nome do Produto *', class: 'form-label' %>
                <%= form.text_field :name, class: 'form-control', required: true, placeholder: 'Ex: Whey Protein 100%' %>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :supplement_type, 'Tipo de Suplemento *', class: 'form-label' %>
                <%= form.select :supplement_type, [
                  ['Whey Protein', 'Whey Protein'],
                  ['Creatina', 'Creatina'],
                  ['BCAA', 'BCAA'],
                  ['Pré-treino', 'Pré-treino'],
                  ['Pós-treino', 'Pós-treino'],
                  ['Multivitamínico', 'Multivitamínico'],
                  ['Ômega 3', 'Ômega 3'],
                  ['Glutamina', 'Glutamina'],
                  ['Caseína', 'Caseína'],
                  ['Albumina', 'Albumina'],
                  ['Termogênico', 'Termogênico'],
                  ['Hipercalórico', 'Hipercalórico'],
                  ['Outros', 'Outros']
                ], { prompt: 'Selecione o tipo' }, class: 'form-select', required: true %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-4 mb-3">
                <%= form.label :flavor, 'Sabor', class: 'form-label' %>
                <%= form.select :flavor, [
                  ['Baunilha', 'Baunilha'],
                  ['Chocolate', 'Chocolate'],
                  ['Morango', 'Morango'],
                  ['Cookies & Cream', 'Cookies & Cream'],
                  ['Doce de Leite', 'Doce de Leite'],
                  ['Açaí', 'Açaí'],
                  ['Sem sabor', 'Sem sabor'],
                  ['Outros', 'Outros']
                ], { prompt: 'Selecione o sabor', include_blank: true }, class: 'form-select' %>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :weight, 'Peso/Quantidade *', class: 'form-label' %>
                <%= form.text_field :weight, class: 'form-control', required: true, placeholder: 'Ex: 900g, 1kg, 2kg' %>
              </div>

              <div class="col-md-4 mb-3">
                <%= form.label :servings_per_container, 'Porções por Embalagem', class: 'form-label' %>
                <%= form.number_field :servings_per_container, class: 'form-control', min: 0, placeholder: 'Ex: 30' %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :protein_per_serving, 'Proteína por Porção', class: 'form-label' %>
                <%= form.text_field :protein_per_serving, class: 'form-control', placeholder: 'Ex: 25g, 30g' %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :manufacturer, 'Fabricante *', class: 'form-label' %>
                <%= form.text_field :manufacturer, class: 'form-control', required: true, placeholder: 'Nome do fabricante' %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :price, 'Preço *', class: 'form-label' %>
                <%= form.number_field :price, class: 'form-control', required: true, min: 0, step: 0.01, placeholder: '0.00' %>
              </div>

              <div class="col-md-3 mb-3">
                <%= form.label :stock_quantity, 'Quantidade em Estoque', class: 'form-label' %>
                <%= form.number_field :stock_quantity, class: 'form-control', min: 0, value: @supplement.stock_quantity || 0 %>
              </div>

              <div class="col-md-3 mb-3">
                <%= form.label :minimum_stock, 'Estoque Mínimo', class: 'form-label' %>
                <%= form.number_field :minimum_stock, class: 'form-control', min: 0, value: @supplement.minimum_stock || 10 %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :description, 'Descrição', class: 'form-label' %>
              <%= form.text_area :description, class: 'form-control', rows: 3, placeholder: 'Descrição geral do produto' %>
            </div>

            <div class="mb-3">
              <%= form.label :nutritional_info, 'Informações Nutricionais', class: 'form-label' %>
              <%= form.text_area :nutritional_info, class: 'form-control', rows: 5, placeholder: 'Informações nutricionais detalhadas (tabela nutricional)' %>
              <div class="form-text">Informe os valores nutricionais completos do produto</div>
            </div>

            <div class="mb-3">
              <%= form.label :usage_instructions, 'Instruções de Uso', class: 'form-label' %>
              <%= form.text_area :usage_instructions, class: 'form-control', rows: 3, placeholder: 'Como usar o produto, quando tomar, etc.' %>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to 'Voltar', supplements_path, class: 'btn btn-secondary' %>
              <%= form.submit 'Cadastrar Suplemento', class: 'btn btn-primary' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
