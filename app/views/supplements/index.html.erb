<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Suplementos</h1>
    <%= link_to 'Novo Suplemento', new_supplement_path, class: 'btn btn-primary' %>
  </div>

  <% if @supplements.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>Nome</th>
            <th>Tipo</th>
            <th>Sabor</th>
            <th>Peso</th>
            <th>Proteína/Porção</th>
            <th>Preço</th>
            <th>Estoque</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @supplements.each do |supplement| %>
            <tr>
              <td><strong><%= supplement.name %></strong></td>
              <td>
                <span class="badge bg-info"><%= supplement.supplement_type %></span>
              </td>
              <td><%= supplement.flavor.present? ? supplement.flavor : '-' %></td>
              <td><%= supplement.weight %></td>
              <td><%= supplement.protein_per_serving.present? ? supplement.protein_per_serving : '-' %></td>
              <td>R$ <%= number_with_precision(supplement.price, precision: 2) %></td>
              <td>
                <span class="badge <%= supplement.in_stock? ? 'bg-success' : 'bg-danger' %>">
                  <%= supplement.stock_quantity %> unidades
                </span>
                <% if supplement.low_stock? %>
                  <span class="badge bg-warning">Estoque baixo</span>
                <% end %>
              </td>
              <td>
                <span class="badge <%= supplement.available_for_sale? ? 'bg-success' : 'bg-secondary' %>">
                  <%= supplement.available_for_sale? ? 'Disponível' : 'Indisponível' %>
                </span>
              </td>
              <td>
                <%= link_to 'Ver', supplement_path(supplement), class: 'btn btn-sm btn-info' %>
                <%= link_to 'Editar', edit_supplement_path(supplement), class: 'btn btn-sm btn-warning' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info">
      <h4>Nenhum suplemento cadastrado</h4>
      <p>Comece cadastrando seu primeiro suplemento.</p>
      <%= link_to 'Cadastrar Primeiro Suplemento', new_supplement_path, class: 'btn btn-primary' %>
    </div>
  <% end %>
</div>
