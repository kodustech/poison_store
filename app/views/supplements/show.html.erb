<div class="container mt-4">
  <div class="row">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <div class="d-flex justify-content-between align-items-center">
            <h2><%= @supplement.name %></h2>
            <div>
              <%= link_to 'Editar', edit_supplement_path(@supplement), class: 'btn btn-warning' %>
              <%= link_to 'Voltar', supplements_path, class: 'btn btn-secondary' %>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <h5>Informações do Produto</h5>
              <table class="table table-borderless">
                <tr>
                  <td><strong>Tipo:</strong></td>
                  <td><span class="badge bg-info fs-6"><%= @supplement.supplement_type %></span></td>
                </tr>
                <tr>
                  <td><strong>Sabor:</strong></td>
                  <td><%= @supplement.flavor.present? ? @supplement.flavor : '-' %></td>
                </tr>
                <tr>
                  <td><strong>Peso:</strong></td>
                  <td><%= @supplement.weight %></td>
                </tr>
                <tr>
                  <td><strong>Porções:</strong></td>
                  <td><%= @supplement.servings_per_container.present? ? "#{@supplement.servings_per_container} porções" : '-' %></td>
                </tr>
                <tr>
                  <td><strong>Proteína por Porção:</strong></td>
                  <td><%= @supplement.protein_per_serving.present? ? @supplement.protein_per_serving : '-' %></td>
                </tr>
                <tr>
                  <td><strong>Fabricante:</strong></td>
                  <td><%= @supplement.manufacturer %></td>
                </tr>
              </table>
            </div>
            <div class="col-md-6">
              <h5>Informações Comerciais</h5>
              <table class="table table-borderless">
                <tr>
                  <td><strong>Preço:</strong></td>
                  <td><span class="h5 text-primary">R$ <%= number_with_precision(@supplement.price, precision: 2) %></span></td>
                </tr>
                <tr>
                  <td><strong>Estoque:</strong></td>
                  <td>
                    <span class="badge <%= @supplement.in_stock? ? 'bg-success' : 'bg-danger' %> fs-6">
                      <%= @supplement.stock_quantity %> unidades
                    </span>
                  </td>
                </tr>
                <tr>
                  <td><strong>Estoque Mínimo:</strong></td>
                  <td><%= @supplement.minimum_stock %> unidades</td>
                </tr>
              </table>
            </div>
          </div>

          <% if @supplement.description.present? %>
            <div class="mt-4">
              <h5>Descrição</h5>
              <p class="text-muted"><%= @supplement.description %></p>
            </div>
          <% end %>

          <% if @supplement.nutritional_info.present? %>
            <div class="mt-4">
              <h5>Informações Nutricionais</h5>
              <div class="bg-light p-3 rounded">
                <pre class="mb-0" style="white-space: pre-wrap; font-family: inherit;"><%= @supplement.nutritional_info %></pre>
              </div>
            </div>
          <% end %>

          <% if @supplement.usage_instructions.present? %>
            <div class="mt-4">
              <h5>Instruções de Uso</h5>
              <p class="text-muted"><%= @supplement.usage_instructions %></p>
            </div>
          <% end %>

          <div class="mt-4">
            <h5>Status do Produto</h5>
            <div class="row">
              <div class="col-md-4">
                <div class="card bg-light">
                  <div class="card-body text-center">
                    <h6>Disponibilidade</h6>
                    <span class="badge <%= @supplement.available_for_sale? ? 'bg-success' : 'bg-danger' %> fs-6">
                      <%= @supplement.available_for_sale? ? 'Disponível' : 'Indisponível' %>
                    </span>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card bg-light">
                  <div class="card-body text-center">
                    <h6>Estoque</h6>
                    <span class="badge <%= @supplement.in_stock? ? 'bg-success' : 'bg-danger' %> fs-6">
                      <%= @supplement.in_stock? ? 'Em Estoque' : 'Sem Estoque' %>
                    </span>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card bg-light">
                  <div class="card-body text-center">
                    <h6>Alerta de Estoque</h6>
                    <span class="badge <%= @supplement.low_stock? ? 'bg-warning' : 'bg-success' %> fs-6">
                      <%= @supplement.low_stock? ? 'Estoque Baixo' : 'Estoque OK' %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <div class="card-header">
          <h5>Ações Rápidas</h5>
        </div>
        <div class="card-body">
          <%= link_to 'Nova Venda', new_medication_sale_path(supplement_id: @supplement.id), 
              class: 'btn btn-primary btn-lg w-100 mb-2' %>
          <%= link_to 'Ver Vendas', medication_sales_path(supplement_id: @supplement.id), 
              class: 'btn btn-outline-info w-100 mb-2' %>
          <%= link_to 'Relatório Mensal', monthly_sales_report_path(year: Date.current.year, month: Date.current.month), 
              class: 'btn btn-outline-success w-100' %>
        </div>
      </div>
    </div>
  </div>
</div>
