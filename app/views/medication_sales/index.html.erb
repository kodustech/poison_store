<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Vendas de Medicamentos</h1>
    <%= link_to 'Nova Venda', new_medication_sale_path, class: 'btn btn-primary' %>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Data</th>
              <th>Cliente</th>
              <th>Medicamento</th>
              <th>Quantidade</th>
              <th>Preço Unit.</th>
              <th>Total</th>
              <th>Desconto</th>
              <th>Receita</th>
              <th>Método Pagamento</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @sales.each do |sale| %>
              <tr>
                <td><%= sale.sale_date.strftime("%d/%m/%Y") %></td>
                <td>
                  <strong><%= sale.customer_name %></strong><br>
                  <small class="text-muted"><%= sale.customer_cpf %></small>
                </td>
                <td>
                  <strong><%= sale.over_the_counter_medication.name %></strong><br>
                  <small class="text-muted"><%= sale.over_the_counter_medication.active_ingredient %></small>
                </td>
                <td><%= sale.quantity %></td>
                <td>R$ <%= number_with_precision(sale.unit_price, precision: 2) %></td>
                <td>
                  <% if sale.discount_applied > 0 %>
                    <div>
                      <span class="text-decoration-line-through text-muted">
                        R$ <%= number_with_precision(sale.original_price, precision: 2) %>
                      </span><br>
                      <strong class="text-success">
                        R$ <%= number_with_precision(sale.total_price, precision: 2) %>
                      </strong>
                    </div>
                  <% else %>
                    <strong>R$ <%= number_with_precision(sale.total_price, precision: 2) %></strong>
                  <% end %>
                </td>
                <td>
                  <% if sale.discount_applied > 0 %>
                    <span class="badge bg-success">
                      <%= number_to_percentage(sale.discount_percentage, precision: 1) %>
                    </span><br>
                    <small class="text-muted">
                      R$ <%= number_with_precision(sale.discount_applied, precision: 2) %>
                    </small>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td>
                  <% if sale.sold_with_prescription %>
                    <span class="badge bg-warning">Com Receita</span>
                    <% if sale.doctor_name.present? %>
                      <br><small class="text-muted">Dr. <%= sale.doctor_name %></small>
                      <% if sale.doctor_crm.present? %>
                        <br><small class="text-muted">CRM: <%= sale.doctor_crm %></small>
                      <% end %>
                    <% end %>
                  <% else %>
                    <span class="badge bg-success">Sem Receita</span>
                  <% end %>
                </td>
                <td><%= sale.payment_method %></td>
                <td>
                  <div class="btn-group" role="group">
                    <%= link_to 'Ver', sale, class: 'btn btn-sm btn-outline-primary' %>
                    <%= link_to 'Editar', edit_medication_sale_path(sale), class: 'btn btn-sm btn-outline-warning' %>
                    <%= link_to 'Remover', sale, method: :delete, 
                        data: { confirm: 'Tem certeza que deseja remover esta venda?' },
                        class: 'btn btn-sm btn-outline-danger' %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
