<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card">
        <div class="card-header">
          <h2>Nova Venda de Medicamento</h2>
        </div>
        <div class="card-body">
          <%= form_with(model: @sale, local: true) do |form| %>
            <% if @sale.errors.any? %>
              <div class="alert alert-danger">
                <h4><%= pluralize(@sale.errors.count, "erro") %> impediram esta venda de ser salva:</h4>
                <ul>
                  <% @sale.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :over_the_counter_medication_id, 'Medicamento', class: 'form-label' %>
                  <%= form.select :over_the_counter_medication_id, 
                      @medications.map { |m| ["#{m.name} - #{m.active_ingredient} (#{m.strength})", m.id] },
                      { prompt: 'Selecione o medicamento' }, 
                      { class: 'form-select', required: true } %>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :sale_date, 'Data da Venda', class: 'form-label' %>
                  <%= form.date_field :sale_date, class: 'form-control', value: Date.current, required: true %>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :customer_name, 'Nome do Cliente', class: 'form-label' %>
                  <%= form.text_field :customer_name, class: 'form-control', required: true %>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :customer_cpf, 'CPF do Cliente', class: 'form-label' %>
                  <%= form.text_field :customer_cpf, class: 'form-control', required: true %>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :customer_phone, 'Telefone', class: 'form-label' %>
                  <%= form.text_field :customer_phone, class: 'form-control', required: true %>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :customer_email, 'E-mail', class: 'form-label' %>
                  <%= form.email_field :customer_email, class: 'form-control', required: true %>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-4">
                <div class="mb-3">
                  <%= form.label :quantity, 'Quantidade', class: 'form-label' %>
                  <%= form.number_field :quantity, class: 'form-control', min: '1', required: true %>
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3">
                  <%= form.label :unit_price, 'Preço Unitário (R$)', class: 'form-label' %>
                  <%= form.number_field :unit_price, class: 'form-control', step: '0.01', min: '0', required: true %>
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3">
                  <%= form.label :payment_method, 'Método de Pagamento', class: 'form-label' %>
                  <%= form.select :payment_method, 
                      ['Dinheiro', 'Cartão de Crédito', 'Cartão de Débito', 'PIX', 'Transferência'],
                      { prompt: 'Selecione o método' }, 
                      { class: 'form-select', required: true } %>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <div class="form-check">
                <%= form.check_box :sold_with_prescription, class: 'form-check-input', id: 'prescription_checkbox' %>
                <%= form.label :sold_with_prescription, 'Vendido com Receita Médica', class: 'form-check-label', for: 'prescription_checkbox' %>
              </div>
            </div>

            <div id="prescription_fields" style="display: none;">
              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <%= form.label :doctor_name, 'Nome do Médico', class: 'form-label' %>
                    <%= form.text_field :doctor_name, class: 'form-control' %>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <%= form.label :doctor_crm, 'CRM do Médico', class: 'form-label' %>
                    <%= form.text_field :doctor_crm, class: 'form-control' %>
                  </div>
                </div>
              </div>
              <div class="mb-3">
                <%= form.label :prescription_reference, 'Referência da Receita', class: 'form-label' %>
                <%= form.text_field :prescription_reference, class: 'form-control', placeholder: 'Número ou código da receita' %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :notes, 'Observações', class: 'form-label' %>
              <%= form.text_area :notes, class: 'form-control', rows: 3, placeholder: 'Observações adicionais sobre a venda' %>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to 'Voltar', medication_sales_path, class: 'btn btn-secondary' %>
              <%= form.submit 'Registrar Venda', class: 'btn btn-primary' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const prescriptionCheckbox = document.getElementById('prescription_checkbox');
  const prescriptionFields = document.getElementById('prescription_fields');
  
  prescriptionCheckbox.addEventListener('change', function() {
    if (this.checked) {
      prescriptionFields.style.display = 'block';
    } else {
      prescriptionFields.style.display = 'none';
    }
  });
});
</script>
